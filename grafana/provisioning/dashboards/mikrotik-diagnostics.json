          "datasource": {
            "type": "prometheus",
            "uid": "admcgbr6g84cgf"
          }
        },
        {
          "expr": "rate(ifOutErrors{job=~\"integrations/snmp/mikro.*\",device=~\"$device\",ifName=~\"ether.*|sfp.*\"}[5m])",
          "legendFormat": "{{device}} {{ifName}} TX",
          "datasource": {
            "type": "prometheus",
            "uid": "admcgbr6g84cgf"
          }
        }
      ]
    },
    {
      "id": 13,
