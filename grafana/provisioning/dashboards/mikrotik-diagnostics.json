        {
          "expr": "rate(ifOutDiscards{job=~\"integrations/snmp/mikro.*\",device=~\"$device\",ifName=~\"ether.*|sfp.*\"}[5m])",
          "legendFormat": "{{device}} {{ifName}} TX",
          "datasource": {
            "type": "prometheus",
            "uid": "admcgbr6g84cgf"
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "table",
      "title": "Link Flaps (time range)",
      "gridPos": {
        "x": 16,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "admcgbr6g84cgf"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(mtxrInterfaceStatsLinkDowns{job=~\"integrations/snmp/mikro.*\",device=~\"$device\"}[$__range]) > 0",
          "legendFormat": "{{device}} {{ifName}}",
          "datasource": {
            "type": "prometheus",
            "uid": "admcgbr6g84cgf"
          }
        }
      ]
