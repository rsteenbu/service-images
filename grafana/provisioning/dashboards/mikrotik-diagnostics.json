      "title": "Errors & Stability",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Interface Errors",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
