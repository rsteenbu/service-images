ssl_certificate /etc/letsencrypt/live/steenburg.net-0001/fullchain.pem; # managed by Certbot
ssl_certificate_key /etc/letsencrypt/live/steenburg.net-0001/privkey.pem; # managed by Certbot

# Authelia login portal
server {
    server_name auth.steenburg.net;
    listen 443 ssl;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:9091;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffer_size 4k;
    }
}

# Homebridge — internal access only
server {
    server_name homebridge.steenburg.net;
    listen 443 ssl;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        allow 192.168.0.0/16;
        deny all;
        auth_basic "Restricted Access";
        auth_basic_user_file /run/secrets/nginx_htpasswd;
        proxy_set_header Host $host;
        proxy_pass http://localhost:8581;
    }
}

# ntop — internal access only
server {
    server_name ntop.steenburg.net;
    listen 443 ssl;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        allow 192.168.0.0/16;
        deny all;
        auth_basic "Restricted Access";
        auth_basic_user_file /run/secrets/nginx_htpasswd;
        proxy_set_header Host localhost;
        proxy_pass http://n100d:4000;
    }
}

# Grafana — Authelia auth for external, bypass for internal
server {
    server_name home.steenburg.net;

    listen [::]:443 ssl ipv6only=on;
    listen 443 ssl;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    include /etc/nginx/snippets/authelia-auth.conf;
    error_page 401 =302 https://auth.steenburg.net/?rd=$scheme://$http_host$request_uri;

    location / {
        return 301 https://$host/grafana;
    }
    location /graphs {
        return 301 https://$host/grafana;
    }
    location /grafana {
        auth_request /authelia/authz;
        proxy_set_header Host $host;
        proxy_pass http://localhost:3000;
    }
}

# Redirect all port 80 to 443
server {
    listen 80 default_server;
    server_name _;
    return 301 https://$host$request_uri;
}
