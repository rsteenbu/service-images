server {
    server_name voron.steenburg.net; 
    listen 443 ssl;
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
    auth_basic "Restricted Access"; # Message displayed in the login prompt
    auth_basic_user_file /run/secrets/nginx_htpasswd;

    location / {
        proxy_pass http://voron:80; # Assuming Mainsail runs on port 80 locally
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /websocket { # For Moonraker/websockets
        proxy_pass http://voron:80/websocket; # Adjust port if needed
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400; # Long timeout for websocket connections
    }
}
